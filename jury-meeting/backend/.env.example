# Copy to backend/.env and fill in. Never commit the real .env.
# Variable names match the team's root .env so traces land in one Weave project.

# --- W&B (Weave tracing + W&B Inference) ---
# Get your key at https://wandb.ai/authorize
WANDB_API_KEY=
WANDB_ENTITY=yamanbicer-mindra
WANDB_PROJECT=company-brain-harness
# Juror answers (visible/spoken output): strong, fast, clean instruct model.
WANDB_INFERENCE_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507
# Routing is classification — a fast instruct model, NOT a reasoning model.
WANDB_ROUTER_MODEL=meta-llama/Llama-3.3-70B-Instruct

# --- ElevenLabs (TTS voices + Scribe STT) ---
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# --- Supabase (the team's decision DB — we only READ it) ---
# Leave blank to run on backend/sample_decision.json offline.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Resend (emails the applicant their decision + meeting join link) ---
# https://resend.com/api-keys  · blank = invites are skipped gracefully.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Decision Harness <onboarding@resend.dev>
# Public origin used to build the join link in emails (the tunnel / Vercel URL).
# Blank → falls back to the request's own origin (fine for local dev).
PUBLIC_BASE_URL=
