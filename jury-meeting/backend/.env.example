# Copy to backend/.env and fill in. Never commit the real .env.
# Variable names match the team's root .env so traces land in one Weave project.

# --- W&B (Weave tracing + W&B Inference) ---
# Get your key at https://wandb.ai/authorize
WANDB_API_KEY=
WANDB_ENTITY=yamanbicer-mindra
WANDB_PROJECT=company-brain-harness
WANDB_INFERENCE_MODEL=meta-llama/Llama-3.1-8B-Instruct

# --- ElevenLabs (TTS voices + Scribe STT) ---
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# --- Supabase (the team's decision DB — we only READ it) ---
# Leave blank to run on backend/sample_decision.json offline.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
